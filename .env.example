# Supabase public config for Next.js runtime
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for backend/API writes when strict RLS is enabled
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Manual patient auth (optional: defaults enabled in development)
ENABLE_MANUAL_PATIENT_AUTH=true
MANUAL_AUTH_SECRET=change-this-secret

# App/API compliance defaults
DEFAULT_APP_ROLE=admin
